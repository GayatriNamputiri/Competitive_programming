using namespace std;

int f(int i, vector<int> &h, vector<int> &dp)
{
    if (i == 0)
        return 0;

    if (dp[i] != -1)
        return dp[i];

    int case1 = f(i - 1, h, dp) + abs(h[i] - h[i - 1]);

    int case2 = INT_MAX;
    if (i > 1)
    {
        case2 = f(i - 2, h, dp) + abs(h[i] - h[i - 2]);
    }

    return dp[i] = min(case1, case2);
}

int frogJump(vector<int> &h)
{
    int n = h.size();
    vector<int> dp(n, -1);

    return f(n - 1, h, dp);
}

int main()
{
    int n;
    cin >> n;

    vector<int> h(n);
    for (int i = 0; i < n; i++)
    {
        cin >> h[i];
    }

    cout << frogJump(h) << endl;
}
